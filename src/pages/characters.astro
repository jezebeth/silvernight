---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const characters = [
  { id: 'night',  name: 'ไนท์ (Night)',   image: `${base}/images/silvernight/characters/night.png` },
  { id: 'yuel',   name: 'ยูเอล (Yuel)',   image: `${base}/images/silvernight/characters/yuel.png` },
  { id: 'lin',    name: 'ลิน (Lin)',       image: `${base}/images/silvernight/characters/lin.png` },
  { id: 'amira',  name: 'อามิรา (Amira)', image: `${base}/images/silvernight/characters/amira.png` },
  { id: 'ihal',   name: 'อิฮัล (Ihal)',   image: `${base}/images/silvernight/characters/ihal.png` },
];
---

<BaseLayout
  title="Silvernight - ตัวละคร"
  description="รายชื่อตัวละครในนิยาย Silvernight พร้อม character sheet"
  activeNav="characters"
>
  <section class="reading-panel" style="max-width:860px">
    <div class="panel-inner-glow" aria-hidden="true"></div>
    <div class="panel-inner-border" aria-hidden="true"></div>

    <header class="chapter-header">
      <div class="thin-line"></div>
      <div class="ornament">✦  ✧  ✦</div>
      <h1>Silvernight</h1>
      <div class="thin-line short"></div>
      <div class="ornament-divider">
        <span class="ornament-line ornament-line-lg ornament-line-left"></span>
        <span class="ornament-star">✦</span>
        <span class="ornament-star-dim">✧</span>
        <span class="ornament-star">✦</span>
        <span class="ornament-line ornament-line-lg ornament-line-right"></span>
      </div>
      <h2>ตัวละคร</h2>
      <div class="ornament-divider" style="margin-top:8px;margin-bottom:0">
        <span class="ornament-line ornament-line-sm ornament-line-left"></span>
        <span class="ornament-star">✦</span>
        <span class="ornament-star-dim">✧</span>
        <span class="ornament-star">✦</span>
        <span class="ornament-line ornament-line-sm ornament-line-right"></span>
      </div>
    </header>

    <nav class="char-quicknav">
      {characters.map((c) => (
        <a href={`#${c.id}`}>{c.name}</a>
      ))}
    </nav>

    <div class="char-list">
      {characters.map((c) => (
        <section id={c.id} class="char-entry">
          <img src={c.image} alt={c.name} />
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
